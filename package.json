{
	"name": "adminProject_react",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
		"format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
		"prepare": "husky",
		"preview": "vite preview"
	},
	"lint-staged": {
		"*.{ts,tsx}": [
			"oxlint --fix",
			"prettier --write"
		],
		"*.{css,json,md}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"@formkit/tempo": "1.0.0",
		"@hookform/resolvers": "5.2.2",
		"@tanstack/react-query": "5.100.6",
		"axios": "1.15.2",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"react-hook-form": "7.74.0",
		"react-router-dom": "7.14.2",
		"zod": "4.3.6",
		"zustand": "5.0.12"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@rolldown/plugin-babel": "^0.2.3",
		"@types/babel__core": "^7.20.5",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"oxlint": "^1.62.0",
		"prettier": "^3.8.3",
		"sass": "1.99.0",
		"typescript": "~6.0.3",
		"vite": "^8.0.10"
	}
}
