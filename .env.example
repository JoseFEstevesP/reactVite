# Variables de entorno para Docker
# Copia este archivo a .env y ajusta los valores

# API URL - URL del backend
VITE_API_URL=http://localhost:3000/api

# Entorno de ejecución
NODE_ENV=development

# Puerto de la aplicación
APP_PORT=5173

# Puerto de Nginx (producción)
NGINX_PORT=80

# =============================================================================
# CONFIGURACIÓN DE ENCRIPTACIÓN
# =============================================================================

# Clave secreta para encriptar datos sensibles con AES-256-GCM (MÍNIMO 32 caracteres)
VITE_ENCRYPTION_KEY=clave_secreta_muy_larga_para_aes_256_gcm_que_debe_tener_al_menos_32_caracteres